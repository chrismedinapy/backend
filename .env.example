# Django
SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated absolute origins. Do not include URL paths or trailing slashes.
# Development example:
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Required only when the frontend sends cookie/session-authenticated unsafe requests.
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# PostgreSQL/PostGIS
POSTGRES_DB=core
POSTGRES_USER=core
POSTGRES_PASSWORD=replace-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# MongoDB
MONGO_INITDB_DATABASE=data
MONGO_HOST=localhost
MONGO_PORT=27017

# RabbitMQ / Celery
RABBITMQ_DEFAULT_HOST=localhost
RABBITMQ_PORTS_1=5672
RABBITMQ_PORTS_2=15672
RABBITMQ_DEFAULT_USER=core
RABBITMQ_DEFAULT_PASS=replace-me
RABBITMQ_DEFAULT_VHOST=/
CELERY_DEBUG=False

# Authentication
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=1
ENCODING=utf-8

# Local ports
DJANGO_PORT=8000
ADMINER_PORT=8080
